# 8080: the container runs caddy as a non-root user, which can't bind :80.
:8080 {
    root * /usr/share/caddy
    encode gzip

    # Passkey/WebAuthn app association for the iOS app: Apple's CDN fetches
    # this exact path and requires an application/json content type (the file
    # is extensionless, so Caddy would not set one on its own).
    header /.well-known/apple-app-site-association Content-Type application/json

    try_files {path} /index.html
    file_server
}
